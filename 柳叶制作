    Value = false,
    Callback = function(state) engineerElbowEnabled = state; updateEngineerAnimConnection() end
})

local elbowActive = false
local elbowConnection = nil
local lastElbowTime = 0
local function getMelee()
    if not lp.Character then return nil end
    for _, item in pairs(lp.Character:GetChildren()) do
        if item:GetAttribute("Melee") then return item end
    end
    for _, item in pairs(lp.Backpack:GetChildren()) do
        if item:GetAttribute("Melee") then return item end
    end
    return nil
end
local function executeElbowStun(zombie)
    local weapon = getMelee()
    if not weapon or weapon.Name ~= "Axe" then return end
    if zombie.State.Value == "Stunned" then return end
    weapon.RemoteEvent:FireServer("BraceBlock")
    weapon.RemoteEvent:FireServer("StopBraceBlock")
    weapon.RemoteEvent:FireServer("FeedbackStun", zombie, zombie.HumanoidRootPart.Position)
end
EngineerTab:Toggle({
    Title = "肘击",
    Desc = "自动肘击僵尸（死亡后需重新开启）",
    Value = false,
    Callback = function(state)
        elbowActive = state
        if state then
            elbowConnection = RunService.Heartbeat:Connect(function()
                if not elbowActive or not lp.Character then return end
                local now = tick()
                if now - lastElbowTime < 0.2 then return end
                lastElbowTime = now
                local humanoid = lp.Character:FindFirstChildOfClass("Humanoid")
                if not humanoid or humanoid.Health <= 0 then return end
                for _, zombie in pairs(workspace.Zombies:GetChildren()) do
                    if zombie:IsA("Model") and zombie:FindFirstChild("HumanoidRootPart") then
                        local distance = (zombie.HumanoidRootPart.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                        if distance <= 45 then executeElbowStun(zombie) end
                    end
                end
            end)
        else
            if elbowConnection then elbowConnection:Disconnect(); elbowConnection = nil end
        end
    end
})

