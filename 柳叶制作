    if ani then animCache_orig = ani; ani.Parent = nil end
    ensurePhysics_orig(hrp_orig, true)
    task.spawn(function()
        while isFlying_orig and char.Parent do
            local mv = ControlModule:GetMoveVector()
            local cf = camera.CFrame
